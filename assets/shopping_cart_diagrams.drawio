        <mxCell id="s7" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="360" y="470" as="sourcePoint" /><mxPoint x="130" y="470" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Separator -->
