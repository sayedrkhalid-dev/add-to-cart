        <!-- 8. Enter promo code -->
        <mxCell id="s8_label" value="8. Enter promo code SAVE20" style="text;html=1;align=left;fontSize=12;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="140" y="530" width="210" height="20" as="geometry" /></mxCell>
        <mxCell id="s8" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="550" as="sourcePoint" /><mxPoint x="360" y="550" as="targetPoint" /></mxGeometry></mxCell>

        <!-- 9. POST /promo/apply -->
        <mxCell id="s9_label" value="9. POST /promo/apply {code}" style="text;html=1;align=left;fontSize=12;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="370" y="570" width="210" height="20" as="geometry" /></mxCell>
        <mxCell id="s9" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="360" y="590" as="sourcePoint" /><mxPoint x="590" y="590" as="targetPoint" /></mxGeometry></mxCell>

        <!-- 10. Return discount -->
