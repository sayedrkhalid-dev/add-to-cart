          <mxGeometry relative="1" as="geometry"><mxPoint x="1280" y="150" as="sourcePoint" /><mxPoint x="1280" y="1100" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- Step labels and arrows -->
        <!-- 1. Click Add to Cart -->
        <mxCell id="s1_label" value="1. Click &#34;Add to Cart&#34;" style="text;html=1;align=left;fontSize=12;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="140" y="190" width="200" height="20" as="geometry" /></mxCell>
        <mxCell id="s1" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="210" as="sourcePoint" /><mxPoint x="360" y="210" as="targetPoint" /></mxGeometry></mxCell>

        <!-- 2. POST /cart/add -->
