        <mxCell id="s14" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="830" as="sourcePoint" /><mxPoint x="1280" y="830" as="targetPoint" /></mxGeometry></mxCell>

