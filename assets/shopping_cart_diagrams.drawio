        <mxCell id="s3" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="590" y="310" as="sourcePoint" /><mxPoint x="820" y="310" as="targetPoint" /></mxGeometry></mxCell>

