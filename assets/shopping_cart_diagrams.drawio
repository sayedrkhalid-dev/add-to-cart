          <mxGeometry x="750" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lh5" value="Order Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
