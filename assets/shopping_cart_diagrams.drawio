        <mxCell id="s15" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1280" y="870" as="sourcePoint" /><mxPoint x="1050" y="870" as="targetPoint" /></mxGeometry></mxCell>

        <!-- 16. Create order record -->
