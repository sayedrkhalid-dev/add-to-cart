        <!-- 11. Show updated total -->
        <mxCell id="s11_label" value="11. Show discounted total" style="text;html=1;align=right;fontSize=12;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="140" y="650" width="210" height="20" as="geometry" /></mxCell>
